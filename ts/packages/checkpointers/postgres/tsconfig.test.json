{
  "//": "Typecheck src + tests. Tests import the built @ilmek/core, so run `tsc -b` first.",
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "rootDir": "."
